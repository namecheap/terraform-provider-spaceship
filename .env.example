# Acceptance-test environment for the Spaceship provider.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#     cp .env.example .env
#
# `make testacc` loads `.env` automatically, so you never have to export these
# by hand. Never commit `.env` — it holds live credentials.

# Required: Spaceship API credentials.
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# Required: a disposable domain that is SAFE TO MODIFY. Acceptance tests
# create, update, import, and destroy real DNS records on this domain.
SPACESHIP_TEST_DOMAIN=example.com

# The Terraform testing framework skips every acceptance test unless TF_ACC is
# set. `make testacc` sets this for you; uncomment it here only if you run the
# tests directly (e.g. `go test -run TestAcc ...`) with this file sourced.
# TF_ACC=1

# Optional: customize the record names the tests use to avoid collisions.
# SPACESHIP_TEST_RECORD_PREFIX=tfacc
# SPACESHIP_TEST_RECORD_NAME=tf-acc
